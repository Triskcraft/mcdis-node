{
	"name": "mc-dis",
	"version": "0.2.2",
	"description": "mc-dis is a node-based application that allows you to stream a Minecraft server console to Discord, enabling remote and efficient server management through a Discord bot. inspired by McDis-RCON",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"default": "./dist/plugin.js"
		},
		"./mod": {
			"types": "./dist/mod.d.ts",
			"default": "./dist/mod.js"
		}
	},
	"bin": {
		"mcdis": "dist/cli.js",
		"mc-dis": "dist/cli.js"
	},
	"files": [
		"dist",
		"docs",
		"API.md",
		"config.example.json",
		".env.example"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx src/cli.ts",
		"start": "node dist/cli.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepack": "pnpm build",
		"prepublishOnly": "pnpm lint && pnpm typecheck && pnpm build"
	},
	"packageManager": "pnpm@10.23.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Triskcraft/mcdis-node"
	},
	"keywords": [
		"minecraft",
		"discord",
		"bot",
		"server",
		"console",
		"rcon"
	],
	"author": "Eli Maciel <tecno_eli@hotmail.com>",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"bugs": {
		"url": "https://github.com/Triskcraft/mcdis-node/issues"
	},
	"homepage": "https://github.com/Triskcraft/mcdis-node#readme",
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.10.1",
		"eslint": "^10.4.1",
		"prettier": "^3.7.4",
		"tsx": "^4.20.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	}
}
